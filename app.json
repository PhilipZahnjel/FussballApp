{
  "expo": {
    "name": "PK-Fußballschule",
    "slug": "pk-fussballschule",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4a6655"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.pkfussballschule.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#4a6655"
      },
      "package": "de.pkfussballschule.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./web/favicon.png"
    }
  }
}
