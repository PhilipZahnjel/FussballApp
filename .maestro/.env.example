# Kopiere diese Datei zu .maestro/.env und trage echte Werte ein.
# .env wird von Git ignoriert (steht in .gitignore).

# App-ID: Entwicklungs-Build → de.pkfussballschule.app
#          Expo Go (Android) → host.exp.exponent
APP_ID=de.pkfussballschule.app

# Kunden-Testaccount (kein Admin!)
TEST_EMAIL=test@beispiel.de
TEST_PASSWORD=dein_passwort
